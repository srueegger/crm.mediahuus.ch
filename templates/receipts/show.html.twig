{% extends "base.html.twig" %}

{% block title %}Quittung {{ document.doc_number }} - {{ parent() }}{% endblock %}

{% block content %}
<div class="max-w-7xl mx-auto py-6 sm:px-6 lg:px-8">
    <div class="px-4 py-6 sm:px-0">
        <!-- Header -->
        <div class="mb-8">
            <div class="flex justify-between items-center">
                <div>
                    <h2 class="text-2xl font-bold text-gray-900">Quittung {{ document.doc_number }}</h2>
                    <p class="text-gray-600">Erstellt am {{ document.created_at|date('d.m.Y') }} um {{ document.created_at|date('H:i') }}</p>
                </div>
                <div class="flex space-x-3">
                    <a href="/"
                       class="mediahuus-button-secondary">
                        ← Zurück zum Dashboard
                    </a>
                    <a href="{{ url_for('receipts.pdf', {id: document.id}) }}" 
                       class="mediahuus-button-primary">
                        📄 PDF herunterladen
                    </a>
                </div>
            </div>
        </div>

        <!-- Receipt Details -->
        <div class="bg-white shadow rounded-lg p-6 mb-6">
            <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                <!-- Document Info -->
                <div>
                    <h3 class="text-lg font-medium text-gray-900 mb-4">Dokument-Informationen</h3>
                    <dl class="space-y-2">
                        <div>
                            <dt class="text-sm font-medium text-gray-500">Nummer:</dt>
                            <dd class="text-sm text-gray-900">{{ document.doc_number }}</dd>
                        </div>
                        <div>
                            <dt class="text-sm font-medium text-gray-500">Datum:</dt>
                            <dd class="text-sm text-gray-900">{{ document.created_at|date('d.m.Y H:i') }}</dd>
                        </div>
                        <div>
                            <dt class="text-sm font-medium text-gray-500">Filiale:</dt>
                            <dd class="text-sm text-gray-900">{{ branch.name }}</dd>
                        </div>
                    </dl>
                </div>

                <!-- Customer Info (only if provided) -->
                {% if document.customer_name != 'Barkauf' or document.customer_street or document.customer_zip or document.customer_city %}
                <div>
                    <h3 class="text-lg font-medium text-gray-900 mb-4">Kundeninformationen</h3>
                    <dl class="space-y-2">
                        {% if document.customer_name != 'Barkauf' %}
                        <div>
                            <dt class="text-sm font-medium text-gray-500">Name:</dt>
                            <dd class="text-sm text-gray-900">{{ document.customer_name }}</dd>
                        </div>
                        {% endif %}
                        {% if document.customer_street %}
                        <div>
                            <dt class="text-sm font-medium text-gray-500">Strasse:</dt>
                            <dd class="text-sm text-gray-900">{{ document.customer_street }}</dd>
                        </div>
                        {% endif %}
                        {% if document.customer_zip or document.customer_city %}
                        <div>
                            <dt class="text-sm font-medium text-gray-500">PLZ / Ort:</dt>
                            <dd class="text-sm text-gray-900">{{ document.customer_zip }} {{ document.customer_city }}</dd>
                        </div>
                        {% endif %}
                    </dl>
                </div>
                {% endif %}

                <!-- Branch Info -->
                <div>
                    <h3 class="text-lg font-medium text-gray-900 mb-4">Filial-Informationen</h3>
                    <dl class="space-y-2">
                        <div>
                            <dt class="text-sm font-medium text-gray-500">Adresse:</dt>
                            <dd class="text-sm text-gray-900">
                                {{ branch.street }}<br>
                                {{ branch.zip }} {{ branch.city }}
                            </dd>
                        </div>
                        {% if branch.phone %}
                        <div>
                            <dt class="text-sm font-medium text-gray-500">Telefon:</dt>
                            <dd class="text-sm text-gray-900">{{ branch.phone }}</dd>
                        </div>
                        {% endif %}
                        {% if branch.email %}
                        <div>
                            <dt class="text-sm font-medium text-gray-500">E-Mail:</dt>
                            <dd class="text-sm text-gray-900">{{ branch.email }}</dd>
                        </div>
                        {% endif %}
                    </dl>
                </div>
            </div>
        </div>

        <!-- Receipt Items -->
        <div class="bg-white shadow rounded-lg p-6">
            <h3 class="text-lg font-medium text-gray-900 mb-4">Verkaufte Produkte/Dienstleistungen</h3>
            
            <div class="overflow-x-auto">
                <table class="min-w-full divide-y divide-gray-200">
                    {% set has_warranty = false %}
                    {% for item in receipt.items %}
                        {% if item.warranty_label %}
                            {% set has_warranty = true %}
                        {% endif %}
                    {% endfor %}
                    <thead class="bg-gray-50">
                        <tr>
                            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">
                                Beschreibung
                            </th>
                            {% if has_warranty %}
                            <th class="px-6 py-3 text-center text-xs font-medium text-gray-500 uppercase tracking-wider">
                                Garantie
                            </th>
                            {% endif %}
                            <th class="px-6 py-3 text-center text-xs font-medium text-gray-500 uppercase tracking-wider">
                                Menge
                            </th>
                            <th class="px-6 py-3 text-right text-xs font-medium text-gray-500 uppercase tracking-wider">
                                Einzelpreis
                            </th>
                            <th class="px-6 py-3 text-right text-xs font-medium text-gray-500 uppercase tracking-wider">
                                Summe
                            </th>
                        </tr>
                    </thead>
                    <tbody class="bg-white divide-y divide-gray-200">
                        {% for item in receipt.items %}
                            <tr>
                                <td class="px-6 py-4 whitespace-pre-wrap text-sm text-gray-900">
                                    {{ item.item_description }}
                                </td>
                                {% if has_warranty %}
                                <td class="px-6 py-4 text-center text-sm text-gray-900">
                                    {{ item.warranty_label ?? '-' }}
                                </td>
                                {% endif %}
                                <td class="px-6 py-4 text-center text-sm text-gray-900">
                                    {{ item.quantity }}
                                </td>
                                <td class="px-6 py-4 text-right text-sm text-gray-900">
                                    {{ item.formatted_unit_price }}
                                </td>
                                <td class="px-6 py-4 text-right text-sm font-medium text-gray-900">
                                    {{ item.formatted_line_total }}
                                </td>
                            </tr>
                        {% endfor %}
                    </tbody>
                    <tfoot class="bg-gray-50">
                        <tr>
                            <td colspan="{{ has_warranty ? 4 : 3 }}" class="px-6 py-4 text-right text-sm font-medium text-gray-900">
                                Gesamtbetrag:
                            </td>
                            <td class="px-6 py-4 text-right text-lg font-bold" style="color: #2d8f3e;">
                                {{ receipt.formatted_total }}
                            </td>
                        </tr>
                    </tfoot>
                </table>
            </div>
        </div>

        <!-- Actions -->
        <div class="mt-6 flex justify-center space-x-4">
            <a href="{{ url_for('receipts.pdf', {id: document.id}) }}" 
               class="mediahuus-button-primary">
                📄 PDF herunterladen
            </a>
            <a href="{{ url_for('receipts.create') }}" 
               class="mediahuus-button-secondary">
                Neue Quittung erstellen
            </a>
        </div>
    </div>
</div>
{% endblock %}