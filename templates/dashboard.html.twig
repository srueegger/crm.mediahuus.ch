{% extends "base.html.twig" %}

{% block title %}Dashboard - {{ parent() }}{% endblock %}

{% block content %}
<div class="max-w-7xl mx-auto py-6 sm:px-6 lg:px-8">
    <div class="px-4 py-6 sm:px-0">
        <div class="mb-8">
            <h2 class="text-2xl font-bold text-gray-900 mb-2">Dashboard</h2>
            <p class="text-gray-600">Willkommen im Mediahuus CRM-System</p>
        </div>

        <!-- Action Cards -->
        <div class="grid grid-cols-2 md:grid-cols-4 gap-4 mb-8">
            <!-- Kostenvoranschlag -->
            <a href="{{ url_for('estimates.create') }}" class="bg-white shadow rounded-lg p-4 hover:shadow-lg transition-shadow group">
                <div class="flex items-center space-x-3">
                    <div class="flex-shrink-0 h-10 w-10 rounded-full bg-emerald-100 flex items-center justify-center">
                        <svg class="h-5 w-5 text-emerald-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
                        </svg>
                    </div>
                    <div>
                        <p class="text-sm font-medium text-gray-900 group-hover:text-emerald-600 transition-colors">Kostenvoranschlag</p>
                        <p class="text-xs text-gray-500">Erstellen</p>
                    </div>
                </div>
            </a>

            <!-- Quittung -->
            <a href="{{ url_for('receipts.create') }}" class="bg-white shadow rounded-lg p-4 hover:shadow-lg transition-shadow group">
                <div class="flex items-center space-x-3">
                    <div class="flex-shrink-0 h-10 w-10 rounded-full bg-emerald-100 flex items-center justify-center">
                        <svg class="h-5 w-5 text-emerald-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 14l6-6m-5.5.5h.01m4.99 5h.01M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16l3.5-2 3.5 2 3.5-2 3.5 2zM13 8.5a1.5 1.5 0 11-3 0 1.5 1.5 0 013 0zm-3 4a1.5 1.5 0 11-3 0 1.5 1.5 0 013 0z" />
                        </svg>
                    </div>
                    <div>
                        <p class="text-sm font-medium text-gray-900 group-hover:text-emerald-600 transition-colors">Quittung</p>
                        <p class="text-xs text-gray-500">Erstellen</p>
                    </div>
                </div>
            </a>

            <!-- Ankauf -->
            <a href="{{ url_for('purchases.create') }}" class="bg-white shadow rounded-lg p-4 hover:shadow-lg transition-shadow group">
                <div class="flex items-center space-x-3">
                    <div class="flex-shrink-0 h-10 w-10 rounded-full bg-emerald-100 flex items-center justify-center">
                        <svg class="h-5 w-5 text-emerald-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
                        </svg>
                    </div>
                    <div>
                        <p class="text-sm font-medium text-gray-900 group-hover:text-emerald-600 transition-colors">Ankauf</p>
                        <p class="text-xs text-gray-500">Erstellen</p>
                    </div>
                </div>
            </a>

            <!-- Benutzerverwaltung -->
            <a href="{{ url_for('users.index') }}" class="bg-white shadow rounded-lg p-4 hover:shadow-lg transition-shadow group">
                <div class="flex items-center space-x-3">
                    <div class="flex-shrink-0 h-10 w-10 rounded-full bg-emerald-100 flex items-center justify-center">
                        <svg class="h-5 w-5 text-emerald-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197m13.5-9a2.5 2.5 0 11-5 0 2.5 2.5 0 015 0z" />
                        </svg>
                    </div>
                    <div>
                        <p class="text-sm font-medium text-gray-900 group-hover:text-emerald-600 transition-colors">Benutzer</p>
                        <p class="text-xs text-gray-500">Verwalten</p>
                    </div>
                </div>
            </a>
        </div>

        <!-- Documents Section -->
        <div class="bg-white shadow overflow-hidden sm:rounded-md">
            <!-- Header with Filters -->
            <div class="px-4 py-4 sm:px-6 border-b border-gray-200">
                <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4">
                    <div>
                        <h3 class="text-lg leading-6 font-medium text-gray-900">Alle Dokumente</h3>
                        <p class="mt-1 text-sm text-gray-500">{{ total_count }} Dokumente{% if filter_type or filter_branch %} (gefiltert){% endif %}</p>
                    </div>
                    <form method="get" action="/" class="flex flex-wrap items-center gap-3">
                        <select name="type" onchange="this.form.submit()" class="text-sm border-gray-300 rounded-md shadow-sm focus:ring-emerald-500 focus:border-emerald-500">
                            <option value="">Alle Typen</option>
                            <option value="estimate" {{ filter_type == 'estimate' ? 'selected' : '' }}>Kostenvoranschlag</option>
                            <option value="receipt" {{ filter_type == 'receipt' ? 'selected' : '' }}>Quittung</option>
                            <option value="purchase" {{ filter_type == 'purchase' ? 'selected' : '' }}>Ankauf</option>
                        </select>
                        <select name="branch" onchange="this.form.submit()" class="text-sm border-gray-300 rounded-md shadow-sm focus:ring-emerald-500 focus:border-emerald-500">
                            <option value="">Alle Filialen</option>
                            {% for branch in branches %}
                                <option value="{{ branch.id }}" {{ filter_branch == branch.id ? 'selected' : '' }}>{{ branch.name }}</option>
                            {% endfor %}
                        </select>
                        {% if filter_type or filter_branch %}
                            <a href="/" class="text-sm text-gray-500 hover:text-gray-700">Filter zurücksetzen</a>
                        {% endif %}
                    </form>
                </div>
            </div>

            {% if documents|length > 0 %}
                <ul class="divide-y divide-gray-200">
                    {% for item in documents %}
                        <li class="px-4 sm:px-6 py-4 hover:bg-gray-50 cursor-pointer transition-colors"
                            onclick="openModal('modal-{{ loop.index }}')">
                            <div class="flex items-center justify-between">
                                <div class="flex items-center space-x-4 min-w-0 flex-1">
                                    <!-- Type Icon -->
                                    <div class="flex-shrink-0">
                                        {% if item.document.doc_type == 'estimate' %}
                                            <div class="h-10 w-10 rounded-full bg-blue-100 flex items-center justify-center">
                                                <svg class="h-5 w-5 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
                                                </svg>
                                            </div>
                                        {% elseif item.document.doc_type == 'receipt' %}
                                            <div class="h-10 w-10 rounded-full bg-emerald-100 flex items-center justify-center">
                                                <svg class="h-5 w-5 text-emerald-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 14l6-6m-5.5.5h.01m4.99 5h.01M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16l3.5-2 3.5 2 3.5-2 3.5 2z" />
                                                </svg>
                                            </div>
                                        {% elseif item.document.doc_type == 'purchase' %}
                                            <div class="h-10 w-10 rounded-full bg-amber-100 flex items-center justify-center">
                                                <svg class="h-5 w-5 text-amber-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
                                                </svg>
                                            </div>
                                        {% endif %}
                                    </div>

                                    <!-- Content -->
                                    <div class="flex-1 min-w-0">
                                        <div class="flex items-center space-x-2 flex-wrap">
                                            <p class="text-sm font-medium text-gray-900">{{ item.document.doc_number }}</p>
                                            {% if item.document.doc_type == 'estimate' %}
                                                <span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium bg-blue-100 text-blue-800">Kostenvoranschlag</span>
                                            {% elseif item.document.doc_type == 'receipt' %}
                                                <span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium bg-emerald-100 text-emerald-800">Quittung</span>
                                            {% elseif item.document.doc_type == 'purchase' %}
                                                <span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium bg-amber-100 text-amber-800">Ankauf</span>
                                            {% endif %}
                                        </div>
                                        <p class="text-sm text-gray-900 mt-0.5">{{ item.document.customer_name }}</p>
                                        <div class="flex items-center space-x-3 text-sm text-gray-500 mt-0.5">
                                            {% if item.estimate %}
                                                <span>{{ item.estimate.device_name }}</span>
                                                <span class="font-medium text-gray-700">{{ item.estimate.formatted_price }}</span>
                                            {% elseif item.purchase %}
                                                <span>{{ item.purchase.device_full_name }}</span>
                                                <span class="font-medium text-gray-700">{{ item.purchase.formatted_price }}</span>
                                            {% elseif item.receipt %}
                                                <span>{{ item.receipt.items|length }} Artikel</span>
                                                <span class="font-medium text-gray-700">{{ item.receipt.formatted_total }}</span>
                                            {% endif %}
                                            <span>{{ item.branch.name }}</span>
                                            <span>{{ item.document.created_at|date('d.m.Y H:i') }}</span>
                                        </div>
                                    </div>
                                </div>

                                <!-- PDF Quick Action -->
                                <div class="flex items-center ml-4 flex-shrink-0">
                                    {% if item.document.doc_type == 'estimate' %}
                                        <a href="{{ url_for('estimates.pdf', {id: item.document.id}) }}"
                                           onclick="event.stopPropagation()"
                                           class="text-emerald-600 hover:text-emerald-800 p-1.5 rounded hover:bg-emerald-50 transition-colors" title="PDF herunterladen">
                                            <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 10v6m0 0l-3-3m3 3l3-3m2 8H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
                                            </svg>
                                        </a>
                                    {% elseif item.document.doc_type == 'receipt' %}
                                        <a href="{{ url_for('receipts.pdf', {id: item.document.id}) }}"
                                           onclick="event.stopPropagation()"
                                           class="text-emerald-600 hover:text-emerald-800 p-1.5 rounded hover:bg-emerald-50 transition-colors" title="PDF herunterladen">
                                            <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 10v6m0 0l-3-3m3 3l3-3m2 8H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
                                            </svg>
                                        </a>
                                    {% elseif item.document.doc_type == 'purchase' %}
                                        <a href="{{ url_for('purchases.pdf', {id: item.document.id}) }}"
                                           onclick="event.stopPropagation()"
                                           class="text-emerald-600 hover:text-emerald-800 p-1.5 rounded hover:bg-emerald-50 transition-colors" title="PDF herunterladen">
                                            <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 10v6m0 0l-3-3m3 3l3-3m2 8H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
                                            </svg>
                                        </a>
                                    {% endif %}
                                </div>
                            </div>
                        </li>
                    {% endfor %}
                </ul>
            {% else %}
                <div class="px-4 py-12 sm:p-12">
                    <div class="text-center text-gray-500">
                        <svg class="mx-auto h-12 w-12 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
                        </svg>
                        <p class="mt-2">{% if filter_type or filter_branch %}Keine Dokumente mit diesen Filtern gefunden{% else %}Noch keine Dokumente erstellt{% endif %}</p>
                    </div>
                </div>
            {% endif %}
        </div>
    </div>
</div>

{# === Detail Modals === #}
{% for item in documents %}
<div id="modal-{{ loop.index }}" class="fixed inset-0 z-50 hidden" aria-modal="true">
    <!-- Backdrop -->
    <div class="fixed inset-0 bg-black/50 transition-opacity" onclick="closeModal('modal-{{ loop.index }}')"></div>

    <!-- Modal Panel -->
    <div class="fixed inset-0 overflow-y-auto">
        <div class="flex min-h-full items-center justify-center p-4">
            <div class="relative bg-white rounded-xl shadow-2xl w-full max-w-2xl max-h-[90vh] overflow-y-auto">

                {# --- Header --- #}
                <div class="sticky top-0 bg-white border-b border-gray-200 px-6 py-4 rounded-t-xl flex items-center justify-between z-10">
                    <div class="flex items-center space-x-3">
                        {% if item.document.doc_type == 'estimate' %}
                            <span class="inline-flex items-center px-2.5 py-1 rounded-full text-xs font-medium bg-blue-100 text-blue-800">Kostenvoranschlag</span>
                        {% elseif item.document.doc_type == 'receipt' %}
                            <span class="inline-flex items-center px-2.5 py-1 rounded-full text-xs font-medium bg-emerald-100 text-emerald-800">Quittung</span>
                        {% elseif item.document.doc_type == 'purchase' %}
                            <span class="inline-flex items-center px-2.5 py-1 rounded-full text-xs font-medium bg-amber-100 text-amber-800">Ankauf</span>
                        {% endif %}
                        <h3 class="text-lg font-semibold text-gray-900">{{ item.document.doc_number }}</h3>
                    </div>
                    <button onclick="closeModal('modal-{{ loop.index }}')" class="text-gray-400 hover:text-gray-600 p-1 rounded-lg hover:bg-gray-100 transition-colors">
                        <svg class="h-6 w-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
                        </svg>
                    </button>
                </div>

                {# --- Body --- #}
                <div class="px-6 py-5 space-y-5">

                    {# -- Kunde -- #}
                    <div>
                        <h4 class="text-xs font-semibold text-gray-400 uppercase tracking-wider mb-2">Kunde</h4>
                        <p class="text-sm font-medium text-gray-900">{{ item.document.customer_name }}</p>
                        {% if item.document.customer_phone %}
                            <p class="text-sm text-gray-600">Tel: {{ item.document.customer_phone }}</p>
                        {% endif %}
                        {% if item.document.customer_email %}
                            <p class="text-sm text-gray-600">E-Mail: {{ item.document.customer_email }}</p>
                        {% endif %}
                    </div>

                    {# -- Filiale -- #}
                    <div>
                        <h4 class="text-xs font-semibold text-gray-400 uppercase tracking-wider mb-2">Filiale</h4>
                        <p class="text-sm font-medium text-gray-900">{{ item.branch.name }}</p>
                        <p class="text-sm text-gray-600">{{ item.branch.full_address }}</p>
                        {% if item.branch.phone %}
                            <p class="text-sm text-gray-600">Tel: {{ item.branch.phone }}</p>
                        {% endif %}
                    </div>

                    {# ============ KOSTENVORANSCHLAG ============ #}
                    {% if item.document.doc_type == 'estimate' and item.estimate %}
                        <div>
                            <h4 class="text-xs font-semibold text-gray-400 uppercase tracking-wider mb-2">Gerät</h4>
                            <p class="text-sm font-medium text-gray-900">{{ item.estimate.device_name }}</p>
                            {% if item.estimate.serial_number %}
                                <p class="text-sm text-gray-600">Seriennummer: {{ item.estimate.serial_number }}</p>
                            {% endif %}
                        </div>

                        <div>
                            <h4 class="text-xs font-semibold text-gray-400 uppercase tracking-wider mb-2">Schadens-/Fehlerbeschreibung</h4>
                            <div class="text-sm text-gray-700 bg-gray-50 rounded-lg p-3">{{ item.estimate.issue_text|raw }}</div>
                        </div>

                        <div class="bg-blue-50 rounded-lg p-4 flex items-center justify-between">
                            <span class="text-sm font-medium text-blue-800">Voraussichtliche Kosten</span>
                            <span class="text-xl font-bold text-blue-900">{{ item.estimate.formatted_price }}</span>
                        </div>

                    {# ============ QUITTUNG ============ #}
                    {% elseif item.document.doc_type == 'receipt' and item.receipt %}
                        <div>
                            <h4 class="text-xs font-semibold text-gray-400 uppercase tracking-wider mb-3">Artikel</h4>
                            <div class="overflow-x-auto">
                                <table class="min-w-full text-sm">
                                    <thead>
                                        <tr class="border-b border-gray-200">
                                            <th class="text-left py-2 pr-4 font-medium text-gray-500">Beschreibung</th>
                                            <th class="text-center py-2 px-2 font-medium text-gray-500">Menge</th>
                                            <th class="text-right py-2 px-2 font-medium text-gray-500">Einzelpreis</th>
                                            <th class="text-right py-2 pl-2 font-medium text-gray-500">Summe</th>
                                        </tr>
                                    </thead>
                                    <tbody class="divide-y divide-gray-100">
                                        {% for receiptItem in item.receipt.items %}
                                            <tr>
                                                <td class="py-2 pr-4 text-gray-900">{{ receiptItem.item_description }}</td>
                                                <td class="py-2 px-2 text-center text-gray-700">{{ receiptItem.quantity }}</td>
                                                <td class="py-2 px-2 text-right text-gray-700">{{ receiptItem.formatted_unit_price }}</td>
                                                <td class="py-2 pl-2 text-right font-medium text-gray-900">{{ receiptItem.formatted_line_total }}</td>
                                            </tr>
                                        {% endfor %}
                                    </tbody>
                                </table>
                            </div>
                        </div>

                        <div class="bg-emerald-50 rounded-lg p-4 flex items-center justify-between">
                            <span class="text-sm font-medium text-emerald-800">Gesamtbetrag</span>
                            <span class="text-xl font-bold text-emerald-900">{{ item.receipt.formatted_total }}</span>
                        </div>

                    {# ============ ANKAUF ============ #}
                    {% elseif item.document.doc_type == 'purchase' and item.purchase %}
                        <div>
                            <h4 class="text-xs font-semibold text-gray-400 uppercase tracking-wider mb-2">Verkäufer-Adresse</h4>
                            <p class="text-sm text-gray-700">{{ item.purchase.seller_address }}</p>
                        </div>

                        <div>
                            <h4 class="text-xs font-semibold text-gray-400 uppercase tracking-wider mb-2">Angekauftes Gerät</h4>
                            <div class="bg-gray-50 rounded-lg p-3 space-y-2">
                                <div class="grid grid-cols-2 gap-3">
                                    <div>
                                        <p class="text-xs text-gray-500">Gerät</p>
                                        <p class="text-sm font-medium text-gray-900">{{ item.purchase.device_full_name }}</p>
                                    </div>
                                    <div>
                                        <p class="text-xs text-gray-500">Gerätetyp</p>
                                        <p class="text-sm text-gray-900">{{ item.purchase.device_type_name }}</p>
                                    </div>
                                </div>
                                {% if item.purchase.imei %}
                                    <div>
                                        <p class="text-xs text-gray-500">IMEI</p>
                                        <p class="text-sm text-gray-900 font-mono">{{ item.purchase.imei }}</p>
                                    </div>
                                {% endif %}
                                {% if item.purchase.serial_number %}
                                    <div>
                                        <p class="text-xs text-gray-500">Seriennummer</p>
                                        <p class="text-sm text-gray-900 font-mono">{{ item.purchase.serial_number }}</p>
                                    </div>
                                {% endif %}
                                {% if item.purchase.device_condition %}
                                    <div>
                                        <p class="text-xs text-gray-500">Zustand</p>
                                        <p class="text-sm text-gray-900">{{ item.purchase.device_condition }}</p>
                                    </div>
                                {% endif %}
                                {% if item.purchase.accessories %}
                                    <div>
                                        <p class="text-xs text-gray-500">Zubehör</p>
                                        <p class="text-sm text-gray-900">{{ item.purchase.accessories }}</p>
                                    </div>
                                {% endif %}
                            </div>
                        </div>

                        <div class="bg-amber-50 rounded-lg p-4 flex items-center justify-between">
                            <span class="text-sm font-medium text-amber-800">Ankaufspreis</span>
                            <span class="text-xl font-bold text-amber-900">{{ item.purchase.formatted_price }}</span>
                        </div>
                    {% endif %}

                    {# -- Datum -- #}
                    <div class="text-xs text-gray-400 pt-2 border-t border-gray-100">
                        Erstellt am {{ item.document.created_at|date('d.m.Y') }} um {{ item.document.created_at|date('H:i') }} Uhr
                    </div>
                </div>

                {# --- Footer --- #}
                <div class="sticky bottom-0 bg-gray-50 border-t border-gray-200 px-6 py-4 rounded-b-xl flex items-center justify-between">
                    <button onclick="closeModal('modal-{{ loop.index }}')" class="text-sm text-gray-600 hover:text-gray-800 transition-colors">
                        Schliessen
                    </button>
                    <div class="flex items-center space-x-3">
                        {% if item.document.doc_type == 'estimate' %}
                            <a href="{{ url_for('estimates.show', {id: item.document.id}) }}"
                               class="inline-flex items-center px-4 py-2 text-sm font-medium text-gray-700 bg-white border border-gray-300 rounded-lg hover:bg-gray-50 transition-colors">
                                Detailseite
                            </a>
                            <a href="{{ url_for('estimates.pdf', {id: item.document.id}) }}"
                               class="inline-flex items-center px-4 py-2 text-sm font-medium text-white bg-emerald-600 rounded-lg hover:bg-emerald-700 transition-colors">
                                <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
