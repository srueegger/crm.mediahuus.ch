{% extends "base.html.twig" %}

{% block title %}Dashboard - {{ parent() }}{% endblock %}

{% block content %}
<div class="max-w-7xl mx-auto py-6 sm:px-6 lg:px-8">
    <div class="px-4 py-6 sm:px-0">
        <div class="mb-8 flex justify-between items-center">
            <div>
                <h2 class="text-2xl font-bold text-gray-900 mb-2">Dashboard</h2>
                <p class="text-gray-600">Willkommen im Mediahuus CRM-System</p>
            </div>
            <button onclick="clearCache()" id="clear-cache-btn"
                    class="text-sm text-gray-500 hover:text-gray-700 px-3 py-1.5 rounded border border-gray-300 hover:bg-gray-50 transition-colors">
                Cache leeren
            </button>
        </div>

        <!-- Action Cards -->
        <div class="grid grid-cols-2 md:grid-cols-5 gap-4 mb-8">
            <a href="{{ url_for('estimates.create') }}" class="bg-white shadow rounded-lg p-4 hover:shadow-lg transition-shadow group">
                <div class="flex items-center space-x-3">
                    <div class="flex-shrink-0 h-10 w-10 rounded-full bg-emerald-100 flex items-center justify-center">
                        <svg class="h-5 w-5 text-emerald-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
                        </svg>
                    </div>
                    <div>
                        <p class="text-sm font-medium text-gray-900 group-hover:text-emerald-600 transition-colors">Kostenvoranschlag</p>
                        <p class="text-xs text-gray-500">Erstellen</p>
                    </div>
                </div>
            </a>
            <a href="{{ url_for('receipts.create') }}" class="bg-white shadow rounded-lg p-4 hover:shadow-lg transition-shadow group">
                <div class="flex items-center space-x-3">
                    <div class="flex-shrink-0 h-10 w-10 rounded-full bg-emerald-100 flex items-center justify-center">
                        <svg class="h-5 w-5 text-emerald-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 14l6-6m-5.5.5h.01m4.99 5h.01M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16l3.5-2 3.5 2 3.5-2 3.5 2zM13 8.5a1.5 1.5 0 11-3 0 1.5 1.5 0 013 0zm-3 4a1.5 1.5 0 11-3 0 1.5 1.5 0 013 0z" />
                        </svg>
                    </div>
                    <div>
                        <p class="text-sm font-medium text-gray-900 group-hover:text-emerald-600 transition-colors">Quittung</p>
                        <p class="text-xs text-gray-500">Erstellen</p>
                    </div>
                </div>
            </a>
            <a href="{{ url_for('purchases.create') }}" class="bg-white shadow rounded-lg p-4 hover:shadow-lg transition-shadow group">
                <div class="flex items-center space-x-3">
                    <div class="flex-shrink-0 h-10 w-10 rounded-full bg-emerald-100 flex items-center justify-center">
                        <svg class="h-5 w-5 text-emerald-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
                        </svg>
                    </div>
                    <div>
                        <p class="text-sm font-medium text-gray-900 group-hover:text-emerald-600 transition-colors">Ankauf</p>
                        <p class="text-xs text-gray-500">Erstellen</p>
                    </div>
                </div>
            </a>
            <a href="{{ url_for('insurance.create') }}" class="bg-white shadow rounded-lg p-4 hover:shadow-lg transition-shadow group">
                <div class="flex items-center space-x-3">
                    <div class="flex-shrink-0 h-10 w-10 rounded-full bg-emerald-100 flex items-center justify-center">
                        <svg class="h-5 w-5 text-emerald-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" />
                        </svg>
                    </div>
                    <div>
                        <p class="text-sm font-medium text-gray-900 group-hover:text-emerald-600 transition-colors">Gutachten</p>
                        <p class="text-xs text-gray-500">Erstellen</p>
                    </div>
                </div>
            </a>
            <a href="{{ url_for('users.index') }}" class="bg-white shadow rounded-lg p-4 hover:shadow-lg transition-shadow group">
                <div class="flex items-center space-x-3">
                    <div class="flex-shrink-0 h-10 w-10 rounded-full bg-emerald-100 flex items-center justify-center">
                        <svg class="h-5 w-5 text-emerald-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197m13.5-9a2.5 2.5 0 11-5 0 2.5 2.5 0 015 0z" />
                        </svg>
                    </div>
                    <div>
                        <p class="text-sm font-medium text-gray-900 group-hover:text-emerald-600 transition-colors">Benutzer</p>
                        <p class="text-xs text-gray-500">Verwalten</p>
                    </div>
                </div>
            </a>
        </div>

        <!-- Documents Section -->
        <div class="bg-white shadow overflow-hidden sm:rounded-md">
            <div class="px-4 py-4 sm:px-6 border-b border-gray-200">
                <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4">
                    <div>
                        <h3 class="text-lg leading-6 font-medium text-gray-900">Alle Dokumente</h3>
                        <p class="mt-1 text-sm text-gray-500">{{ total_count }} Dokumente{% if filter_type or filter_branch %} (gefiltert){% endif %}</p>
                    </div>
                    <form method="get" action="/" class="flex flex-wrap items-center gap-3">
                        <select name="type" onchange="this.form.submit()" class="text-sm border-gray-300 rounded-md shadow-sm focus:ring-emerald-500 focus:border-emerald-500">
                            <option value="">Alle Typen</option>
                            <option value="estimate" {{ filter_type == 'estimate' ? 'selected' : '' }}>Kostenvoranschlag</option>
                            <option value="receipt" {{ filter_type == 'receipt' ? 'selected' : '' }}>Quittung</option>
                            <option value="purchase" {{ filter_type == 'purchase' ? 'selected' : '' }}>Ankauf</option>
                            <option value="insurance" {{ filter_type == 'insurance' ? 'selected' : '' }}>Versicherungsgutachten</option>
                        </select>
                        <select name="branch" onchange="this.form.submit()" class="text-sm border-gray-300 rounded-md shadow-sm focus:ring-emerald-500 focus:border-emerald-500">
                            <option value="">Alle Filialen</option>
                            {% for branch in branches %}
                                <option value="{{ branch.id }}" {{ filter_branch == branch.id ? 'selected' : '' }}>{{ branch.name }}</option>
                            {% endfor %}
                        </select>
                        {% if filter_type or filter_branch %}
                            <a href="/" class="text-sm text-gray-500 hover:text-gray-700">Filter zurücksetzen</a>
                        {% endif %}
                    </form>
                </div>
            </div>

            {% if documents|length > 0 %}
                <ul class="divide-y divide-gray-200">
                    {% for item in documents %}
                        <li class="px-4 sm:px-6 py-4 hover:bg-gray-50 cursor-pointer transition-colors"
                            onclick="openModal('modal-{{ loop.index }}')">
                            <div class="flex items-center justify-between">
                                <div class="flex items-center space-x-4 min-w-0 flex-1">
                                    <div class="flex-shrink-0">
                                        {% if item.document.doc_type == 'estimate' %}
                                            <div class="h-10 w-10 rounded-full bg-blue-100 flex items-center justify-center">
                                                <svg class="h-5 w-5 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
                                                </svg>
                                            </div>
                                        {% elseif item.document.doc_type == 'receipt' %}
                                            <div class="h-10 w-10 rounded-full bg-emerald-100 flex items-center justify-center">
                                                <svg class="h-5 w-5 text-emerald-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 14l6-6m-5.5.5h.01m4.99 5h.01M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16l3.5-2 3.5 2 3.5-2 3.5 2z" />
                                                </svg>
                                            </div>
                                        {% elseif item.document.doc_type == 'purchase' %}
                                            <div class="h-10 w-10 rounded-full bg-amber-100 flex items-center justify-center">
                                                <svg class="h-5 w-5 text-amber-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
                                                </svg>
                                            </div>
                                        {% elseif item.document.doc_type == 'insurance' %}
                                            <div class="h-10 w-10 rounded-full bg-red-100 flex items-center justify-center">
                                                <svg class="h-5 w-5 text-red-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" />
                                                </svg>
                                            </div>
                                        {% endif %}
                                    </div>
                                    <div class="flex-1 min-w-0">
                                        <div class="flex items-center space-x-2 flex-wrap">
                                            <p class="text-sm font-medium text-gray-900">{{ item.document.doc_number }}</p>
                                            {% if item.document.doc_type == 'estimate' %}
                                                <span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium bg-blue-100 text-blue-800">Kostenvoranschlag</span>
                                            {% elseif item.document.doc_type == 'receipt' %}
                                                <span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium bg-emerald-100 text-emerald-800">Quittung</span>
                                            {% elseif item.document.doc_type == 'purchase' %}
                                                <span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium bg-amber-100 text-amber-800">Ankauf</span>
                                            {% elseif item.document.doc_type == 'insurance' %}
                                                <span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium bg-red-100 text-red-800">Gutachten</span>
                                            {% endif %}
                                        </div>
                                        <p class="text-sm text-gray-900 mt-0.5">{{ item.document.customer_name }}</p>
                                        <div class="flex items-center space-x-3 text-sm text-gray-500 mt-0.5">
                                            {% if item.estimate %}
                                                <span>{{ item.estimate.device_name }}</span>
                                                <span class="font-medium text-gray-700">{{ item.estimate.formatted_price }}</span>
                                            {% elseif item.purchase %}
                                                <span>{{ item.purchase.device_full_name }}</span>
                                                <span class="font-medium text-gray-700">{{ item.purchase.formatted_price }}</span>
                                            {% elseif item.receipt %}
                                                <span>{{ item.receipt.items|length }} Artikel</span>
                                                <span class="font-medium text-gray-700">{{ item.receipt.formatted_total }}</span>
                                            {% elseif item.insurance %}
                                                <span>{{ item.insurance.device_name }}</span>
                                                <span class="font-medium text-gray-700">{{ item.insurance.assessment_result_label }}</span>
                                            {% endif %}
                                            <span>{{ item.branch.name }}</span>
                                            <span>{{ item.document.created_at|date('d.m.Y H:i') }}</span>
                                        </div>
                                    </div>
                                </div>
                                <div class="flex items-center ml-4 flex-shrink-0">
                                    {% if item.document.doc_type == 'estimate' %}
                                        <a href="{{ url_for('estimates.pdf', {id: item.document.id}) }}"
                                           onclick="event.stopPropagation()"
                                           class="text-emerald-600 hover:text-emerald-800 p-1.5 rounded hover:bg-emerald-50 transition-colors" title="PDF herunterladen">
                                            <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 10v6m0 0l-3-3m3 3l3-3m2 8H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
                                            </svg>
                                        </a>
                                    {% elseif item.document.doc_type == 'receipt' %}
                                        <a href="{{ url_for('receipts.pdf', {id: item.document.id}) }}"
                                           onclick="event.stopPropagation()"
                                           class="text-emerald-600 hover:text-emerald-800 p-1.5 rounded hover:bg-emerald-50 transition-colors" title="PDF herunterladen">
                                            <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 10v6m0 0l-3-3m3 3l3-3m2 8H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
                                            </svg>
                                        </a>
                                    {% elseif item.document.doc_type == 'purchase' %}
                                        <a href="{{ url_for('purchases.pdf', {id: item.document.id}) }}"
                                           onclick="event.stopPropagation()"
                                           class="text-emerald-600 hover:text-emerald-800 p-1.5 rounded hover:bg-emerald-50 transition-colors" title="PDF herunterladen">
                                            <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 10v6m0 0l-3-3m3 3l3-3m2 8H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
                                            </svg>
                                        </a>
                                    {% elseif item.document.doc_type == 'insurance' %}
                                        <a href="{{ url_for('insurance.pdf', {id: item.document.id}) }}"
                                           onclick="event.stopPropagation()"
                                           class="text-emerald-600 hover:text-emerald-800 p-1.5 rounded hover:bg-emerald-50 transition-colors" title="PDF herunterladen">
                                            <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 10v6m0 0l-3-3m3 3l3-3m2 8H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
                                            </svg>
                                        </a>
                                    {% endif %}
                                </div>
                            </div>
                        </li>
                    {% endfor %}
                </ul>
            {% else %}
                <div class="px-4 py-12 sm:p-12">
                    <div class="text-center text-gray-500">
                        <svg class="mx-auto h-12 w-12 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
                        </svg>
                        <p class="mt-2">{% if filter_type or filter_branch %}Keine Dokumente mit diesen Filtern gefunden{% else %}Noch keine Dokumente erstellt{% endif %}</p>
                    </div>
                </div>
            {% endif %}
        </div>
    </div>
</div>

{# === Detail Modals === #}
{% for item in documents %}
<div id="modal-{{ loop.index }}" class="fixed inset-0 z-50 hidden" aria-modal="true">
    <!-- Backdrop -->
    <div class="fixed inset-0 bg-gray-900 bg-opacity-50" onclick="closeModal('modal-{{ loop.index }}')"></div>

    <!-- Modal Panel -->
    <div class="fixed inset-0 overflow-y-auto">
        <div class="flex min-h-full items-start justify-center p-4 pt-16">
            <div class="relative bg-white rounded-xl shadow-2xl w-full max-w-2xl">

                {# --- Header mit X-Button --- #}
                <div style="background-color: #f9fafb; border-bottom: 1px solid #e5e7eb; padding: 16px 24px; border-radius: 12px 12px 0 0; display: flex; align-items: center; justify-content: space-between;">
                    <div style="display: flex; align-items: center; gap: 12px;">
                        {% if item.document.doc_type == 'estimate' %}
                            <span style="background-color: #dbeafe; color: #1e40af; padding: 4px 10px; border-radius: 9999px; font-size: 12px; font-weight: 500;">Kostenvoranschlag</span>
                        {% elseif item.document.doc_type == 'receipt' %}
                            <span style="background-color: #d1fae5; color: #065f46; padding: 4px 10px; border-radius: 9999px; font-size: 12px; font-weight: 500;">Quittung</span>
                        {% elseif item.document.doc_type == 'purchase' %}
                            <span style="background-color: #fef3c7; color: #92400e; padding: 4px 10px; border-radius: 9999px; font-size: 12px; font-weight: 500;">Ankauf</span>
                        {% elseif item.document.doc_type == 'insurance' %}
                            <span style="background-color: #fee2e2; color: #991b1b; padding: 4px 10px; border-radius: 9999px; font-size: 12px; font-weight: 500;">Gutachten</span>
                        {% endif %}
                        <strong style="font-size: 18px; color: #111827;">{{ item.document.doc_number }}</strong>
                    </div>
                    <button onclick="closeModal('modal-{{ loop.index }}')" style="color: #9ca3af; padding: 4px; cursor: pointer; background: none; border: none;">
                        <svg width="24" height="24" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
                        </svg>
                    </button>
                </div>

                {# --- Body --- #}
                <div style="padding: 24px;">

                    {# -- Kunde -- #}
                    <div style="margin-bottom: 20px;">
                        <p style="font-size: 11px; font-weight: 600; color: #9ca3af; text-transform: uppercase; letter-spacing: 0.05em; margin-bottom: 6px;">Kunde</p>
                        <p style="font-size: 14px; font-weight: 500; color: #111827;">{{ item.document.customer_name }}</p>
                        {% if item.document.customer_phone %}
                            <p style="font-size: 14px; color: #4b5563;">Tel: {{ item.document.customer_phone }}</p>
                        {% endif %}
                        {% if item.document.customer_email %}
                            <p style="font-size: 14px; color: #4b5563;">E-Mail: {{ item.document.customer_email }}</p>
                        {% endif %}
                    </div>

                    {# -- Filiale -- #}
                    <div style="margin-bottom: 20px;">
                        <p style="font-size: 11px; font-weight: 600; color: #9ca3af; text-transform: uppercase; letter-spacing: 0.05em; margin-bottom: 6px;">Filiale</p>
                        <p style="font-size: 14px; font-weight: 500; color: #111827;">{{ item.branch.name }}</p>
                        <p style="font-size: 14px; color: #4b5563;">{{ item.branch.full_address }}</p>
                        {% if item.branch.phone %}
                            <p style="font-size: 14px; color: #4b5563;">Tel: {{ item.branch.phone }}</p>
                        {% endif %}
                    </div>

                    {# ============ KOSTENVORANSCHLAG ============ #}
                    {% if item.document.doc_type == 'estimate' and item.estimate %}
                        <div style="margin-bottom: 20px;">
                            <p style="font-size: 11px; font-weight: 600; color: #9ca3af; text-transform: uppercase; letter-spacing: 0.05em; margin-bottom: 6px;">Gerät</p>
                            <p style="font-size: 14px; font-weight: 500; color: #111827;">{{ item.estimate.device_name }}</p>
                            {% if item.estimate.serial_number %}
                                <p style="font-size: 14px; color: #4b5563;">Seriennummer: {{ item.estimate.serial_number }}</p>
                            {% endif %}
                        </div>

                        <div style="margin-bottom: 20px;">
                            <p style="font-size: 11px; font-weight: 600; color: #9ca3af; text-transform: uppercase; letter-spacing: 0.05em; margin-bottom: 6px;">Schadens-/Fehlerbeschreibung</p>
                            <div style="font-size: 14px; color: #374151; background: #f9fafb; border-radius: 8px; padding: 12px;">{{ item.estimate.issue_text|raw }}</div>
                        </div>

                        <div style="background: #eff6ff; border-radius: 8px; padding: 16px; display: flex; align-items: center; justify-content: space-between; margin-bottom: 24px;">
                            <span style="font-size: 14px; font-weight: 500; color: #1e40af;">Voraussichtliche Kosten</span>
                            <span style="font-size: 20px; font-weight: 700; color: #1e3a8a;">{{ item.estimate.formatted_price }}</span>
                        </div>

                    {# ============ QUITTUNG ============ #}
                    {% elseif item.document.doc_type == 'receipt' and item.receipt %}
                        <div style="margin-bottom: 20px;">
                            <p style="font-size: 11px; font-weight: 600; color: #9ca3af; text-transform: uppercase; letter-spacing: 0.05em; margin-bottom: 10px;">Artikel</p>
                            <table style="width: 100%; font-size: 14px; border-collapse: collapse;">
                                <thead>
                                    <tr style="border-bottom: 1px solid #e5e7eb;">
                                        <th style="text-align: left; padding: 8px 8px 8px 0; font-weight: 500; color: #6b7280;">Beschreibung</th>
                                        <th style="text-align: center; padding: 8px 4px; font-weight: 500; color: #6b7280;">Menge</th>
                                        <th style="text-align: right; padding: 8px 4px; font-weight: 500; color: #6b7280;">Einzelpreis</th>
                                        <th style="text-align: right; padding: 8px 0 8px 4px; font-weight: 500; color: #6b7280;">Summe</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    {% for receiptItem in item.receipt.items %}
                                        <tr style="border-bottom: 1px solid #f3f4f6;">
                                            <td style="padding: 8px 8px 8px 0; color: #111827;">{{ receiptItem.item_description }}</td>
                                            <td style="padding: 8px 4px; text-align: center; color: #374151;">{{ receiptItem.quantity }}</td>
                                            <td style="padding: 8px 4px; text-align: right; color: #374151;">{{ receiptItem.formatted_unit_price }}</td>
                                            <td style="padding: 8px 0 8px 4px; text-align: right; font-weight: 500; color: #111827;">{{ receiptItem.formatted_line_total }}</td>
                                        </tr>
                                    {% endfor %}
                                </tbody>
                            </table>
                        </div>

                        <div style="background: #ecfdf5; border-radius: 8px; padding: 16px; display: flex; align-items: center; justify-content: space-between; margin-bottom: 24px;">
                            <span style="font-size: 14px; font-weight: 500; color: #065f46;">Gesamtbetrag</span>
                            <span style="font-size: 20px; font-weight: 700; color: #064e3b;">{{ item.receipt.formatted_total }}</span>
                        </div>

                    {# ============ ANKAUF ============ #}
                    {% elseif item.document.doc_type == 'purchase' and item.purchase %}
                        <div style="margin-bottom: 20px;">
                            <p style="font-size: 11px; font-weight: 600; color: #9ca3af; text-transform: uppercase; letter-spacing: 0.05em; margin-bottom: 6px;">Verkäufer-Adresse</p>
                            <p style="font-size: 14px; color: #374151;">{{ item.purchase.seller_address }}</p>
                        </div>

                        <div style="margin-bottom: 20px;">
                            <p style="font-size: 11px; font-weight: 600; color: #9ca3af; text-transform: uppercase; letter-spacing: 0.05em; margin-bottom: 6px;">Angekauftes Gerät</p>
                            <div style="background: #f9fafb; border-radius: 8px; padding: 12px;">
                                <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 12px;">
                                    <div>
                                        <p style="font-size: 12px; color: #6b7280;">Gerät</p>
                                        <p style="font-size: 14px; font-weight: 500; color: #111827;">{{ item.purchase.device_full_name }}</p>
                                    </div>
                                    <div>
                                        <p style="font-size: 12px; color: #6b7280;">Gerätetyp</p>
                                        <p style="font-size: 14px; color: #111827;">{{ item.purchase.device_type_name }}</p>
                                    </div>
                                </div>
                                {% if item.purchase.imei %}
                                    <div style="margin-top: 8px;">
                                        <p style="font-size: 12px; color: #6b7280;">IMEI</p>
                                        <p style="font-size: 14px; color: #111827; font-family: monospace;">{{ item.purchase.imei }}</p>
                                    </div>
                                {% endif %}
                                {% if item.purchase.serial_number %}
                                    <div style="margin-top: 8px;">
                                        <p style="font-size: 12px; color: #6b7280;">Seriennummer</p>
                                        <p style="font-size: 14px; color: #111827; font-family: monospace;">{{ item.purchase.serial_number }}</p>
                                    </div>
                                {% endif %}
                                {% if item.purchase.device_condition %}
                                    <div style="margin-top: 8px;">
                                        <p style="font-size: 12px; color: #6b7280;">Zustand</p>
                                        <p style="font-size: 14px; color: #111827;">{{ item.purchase.device_condition }}</p>
                                    </div>
                                {% endif %}
                                {% if item.purchase.accessories %}
                                    <div style="margin-top: 8px;">
                                        <p style="font-size: 12px; color: #6b7280;">Zubehör</p>
                                        <p style="font-size: 14px; color: #111827;">{{ item.purchase.accessories }}</p>
                                    </div>
                                {% endif %}
                            </div>
                        </div>

                        <div style="background: #fffbeb; border-radius: 8px; padding: 16px; display: flex; align-items: center; justify-content: space-between; margin-bottom: 24px;">
                            <span style="font-size: 14px; font-weight: 500; color: #92400e;">Ankaufspreis</span>
                            <span style="font-size: 20px; font-weight: 700; color: #78350f;">{{ item.purchase.formatted_price }}</span>
                        </div>

                    {# ============ VERSICHERUNGSGUTACHTEN ============ #}
                    {% elseif item.document.doc_type == 'insurance' and item.insurance %}
                        <div style="margin-bottom: 20px;">
                            <p style="font-size: 11px; font-weight: 600; color: #9ca3af; text-transform: uppercase; letter-spacing: 0.05em; margin-bottom: 6px;">Kunden-Adresse</p>
                            <p style="font-size: 14px; color: #374151;">{{ item.insurance.customer_address }}</p>
                        </div>

                        <div style="margin-bottom: 20px;">
                            <p style="font-size: 11px; font-weight: 600; color: #9ca3af; text-transform: uppercase; letter-spacing: 0.05em; margin-bottom: 6px;">Gerät</p>
                            <div style="background: #f9fafb; border-radius: 8px; padding: 12px;">
                                <p style="font-size: 14px; font-weight: 500; color: #111827;">{{ item.insurance.device_name }}</p>
                                <p style="font-size: 14px; color: #4b5563; font-family: monospace;">SN/IMEI: {{ item.insurance.serial_number }}</p>
                            </div>
                        </div>

                        {% if item.insurance.damage_description %}
                        <div style="margin-bottom: 20px;">
                            <p style="font-size: 11px; font-weight: 600; color: #9ca3af; text-transform: uppercase; letter-spacing: 0.05em; margin-bottom: 6px;">Schadensbeschreibung</p>
                            <div style="font-size: 14px; color: #374151; background: #f9fafb; border-radius: 8px; padding: 12px;">{{ item.insurance.damage_description|raw }}</div>
                        </div>
                        {% endif %}

                        <div style="margin-bottom: 20px;">
                            <p style="font-size: 11px; font-weight: 600; color: #9ca3af; text-transform: uppercase; letter-spacing: 0.05em; margin-bottom: 6px;">Bewertungsergebnis</p>
                            {% if item.insurance.assessment_result == 'total_loss' %}
                                <div style="background: #fef2f2; border-radius: 8px; padding: 16px; text-align: center;">
                                    <p style="font-size: 18px; font-weight: 700; color: #991b1b;">{{ item.insurance.assessment_result_label }}</p>
                                </div>
                            {% elseif item.insurance.assessment_result == 'repair_recommended' %}
                                <div style="background: #ecfdf5; border-radius: 8px; padding: 16px; text-align: center;">
                                    <p style="font-size: 18px; font-weight: 700; color: #065f46;">{{ item.insurance.assessment_result_label }}</p>
                                </div>
                            {% else %}
                                <div style="background: #f3f4f6; border-radius: 8px; padding: 16px; text-align: center;">
                                    <p style="font-size: 18px; font-weight: 700; color: #374151;">{{ item.insurance.assessment_result_label }}</p>
                                </div>
                            {% endif %}
                        </div>

                        {% if item.insurance.formatted_device_value or item.insurance.formatted_repair_cost %}
                        <div style="display: grid; grid-template-columns: {% if item.insurance.formatted_device_value and item.insurance.formatted_repair_cost %}1fr 1fr{% else %}1fr{% endif %}; gap: 12px; margin-bottom: 24px;">
                            {% if item.insurance.formatted_device_value %}
                            <div style="background: #f9fafb; border-radius: 8px; padding: 12px; text-align: center;">
                                <p style="font-size: 12px; color: #6b7280; margin-bottom: 4px;">Geschätzter Zeitwert</p>
                                <p style="font-size: 18px; font-weight: 700; color: #111827;">{{ item.insurance.formatted_device_value }}</p>
                            </div>
                            {% endif %}
                            {% if item.insurance.formatted_repair_cost %}
                            <div style="background: #f9fafb; border-radius: 8px; padding: 12px; text-align: center;">
                                <p style="font-size: 12px; color: #6b7280; margin-bottom: 4px;">Reparaturkosten</p>
                                <p style="font-size: 18px; font-weight: 700; color: #111827;">{{ item.insurance.formatted_repair_cost }}</p>
                            </div>
                            {% endif %}
                        </div>
                        {% endif %}
                    {% endif %}

                    {# -- Datum -- #}
                    <p style="font-size: 12px; color: #9ca3af; margin-bottom: 20px;">
                        Erstellt am {{ item.document.created_at|date('d.m.Y') }} um {{ item.document.created_at|date('H:i') }} Uhr
                    </p>

                    {# ====== AKTIONS-BUTTONS (im Body, immer sichtbar) ====== #}
                    <div style="border-top: 1px solid #e5e7eb; padding-top: 20px; display: flex; gap: 12px; flex-wrap: wrap;">
                        {% if item.document.doc_type == 'estimate' %}
                            <a href="{{ url_for('estimates.pdf', {id: item.document.id}) }}" class="mediahuus-button-primary" style="flex: 1; text-align: center; display: flex; align-items: center; justify-content: center; gap: 8px;">
                                <svg width="20" height="20" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 10v6m0 0l-3-3m3 3l3-3m2 8H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
                                </svg>
                                PDF herunterladen
                            </a>
                            <a href="{{ url_for('estimates.show', {id: item.document.id}) }}" class="mediahuus-button-secondary" style="text-align: center;">
                                Detailseite
                            </a>
                        {% elseif item.document.doc_type == 'receipt' %}
                            <a href="{{ url_for('receipts.pdf', {id: item.document.id}) }}" class="mediahuus-button-primary" style="flex: 1; text-align: center; display: flex; align-items: center; justify-content: center; gap: 8px;">
                                <svg width="20" height="20" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 10v6m0 0l-3-3m3 3l3-3m2 8H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
                                </svg>
                                PDF herunterladen
                            </a>
                            <a href="{{ url_for('receipts.show', {id: item.document.id}) }}" class="mediahuus-button-secondary" style="text-align: center;">
                                Detailseite
                            </a>
                        {% elseif item.document.doc_type == 'purchase' %}
                            <a href="{{ url_for('purchases.pdf', {id: item.document.id}) }}" class="mediahuus-button-primary" style="flex: 1; text-align: center; display: flex; align-items: center; justify-content: center; gap: 8px;">
                                <svg width="20" height="20" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 10v6m0 0l-3-3m3 3l3-3m2 8H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
                                </svg>
                                PDF herunterladen
                            </a>
                            <a href="{{ url_for('purchases.show', {id: item.document.id}) }}" class="mediahuus-button-secondary" style="text-align: center;">
                                Detailseite
                            </a>
                        {% elseif item.document.doc_type == 'insurance' %}
                            <a href="{{ url_for('insurance.pdf', {id: item.document.id}) }}" class="mediahuus-button-primary" style="flex: 1; text-align: center; display: flex; align-items: center; justify-content: center; gap: 8px;">
                                <svg width="20" height="20" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 10v6m0 0l-3-3m3 3l3-3m2 8H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
                                </svg>
                                PDF herunterladen
                            </a>
                            <a href="{{ url_for('insurance.show', {id: item.document.id}) }}" class="mediahuus-button-secondary" style="text-align: center;">
                                Detailseite
                            </a>
                        {% endif %}
                    </div>

                </div>
            </div>
        </div>
    </div>
</div>
{% endfor %}
{% endblock %}

{% block scripts %}
<script>
function openModal(id) {
    var modal = document.getElementById(id);
    if (!modal) return;
    modal.classList.remove('hidden');
    document.body.style.overflow = 'hidden';
}

function closeModal(id) {
    var modal = document.getElementById(id);
    if (!modal) return;
    modal.classList.add('hidden');
    document.body.style.overflow = '';
}

document.addEventListener('keydown', function(e) {
    if (e.key === 'Escape') {
        var modals = document.querySelectorAll('[id^="modal-"]:not(.hidden)');
        for (var i = 0; i < modals.length; i++) {
            modals[i].classList.add('hidden');
        }
        document.body.style.overflow = '';
    }
});

function clearCache() {
    var btn = document.getElementById('clear-cache-btn');
    btn.textContent = 'Wird geleert...';
    btn.disabled = true;
    fetch('/clear-cache', { method: 'POST' })
        .then(function(r) { return r.json(); })
        .then(function(data) {
            btn.textContent = data.success ? 'Geleert!' : 'Fehler';
            setTimeout(function() {
                btn.textContent = 'Cache leeren';
                btn.disabled = false;
            }, 2000);
        })
        .catch(function() {
            btn.textContent = 'Cache leeren';
            btn.disabled = false;
        });
}
</script>
{% endblock %}
