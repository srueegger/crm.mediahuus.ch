{% extends "base.html.twig" %}

{% block title %}Versicherungsgutachten {{ document.doc_number }} - {{ parent() }}{% endblock %}

{% block content %}
<div class="max-w-4xl mx-auto py-6 sm:px-6 lg:px-8">
    <div class="px-4 py-6 sm:px-0">
        <!-- Header -->
        <div class="mb-8 flex justify-between items-start">
            <div>
                <h2 class="text-2xl font-bold text-gray-900 mb-2">Versicherungsgutachten {{ document.doc_number }}</h2>
                <p class="text-gray-600">Erstellt am {{ document.created_at|date('d.m.Y H:i') }} Uhr</p>
            </div>
            <div class="flex gap-3">
                <a href="/"
                   class="px-4 py-2 border border-gray-300 rounded-lg text-gray-700 hover:bg-gray-50 transition-colors">
                    Zurück zum Dashboard
                </a>
                <a href="{{ url_for('insurance.pdf', {id: document.id}) }}"
                   class="mediahuus-button-primary inline-flex items-center gap-2">
                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 10v6m0 0l-3-3m3 3l3-3m2 8H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/>
                    </svg>
                    PDF herunterladen
                </a>
            </div>
        </div>

        <div class="space-y-6">
            <!-- Filiale -->
            <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-6">
                <h3 class="text-lg font-medium text-gray-900 mb-4 flex items-center">
                    <svg class="w-5 h-5 text-emerald-600 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"/>
                    </svg>
                    Filiale
                </h3>
                <p class="text-gray-900 font-medium">{{ branch.name }}</p>
                <p class="text-sm text-gray-600">{{ branch.full_address }}</p>
            </div>

            <!-- Kunde -->
            <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-6">
                <h3 class="text-lg font-medium text-gray-900 mb-4 flex items-center">
                    <svg class="w-5 h-5 text-emerald-600 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/>
                    </svg>
                    Kunde
                </h3>
                <div class="space-y-2">
                    <div>
                        <p class="text-sm font-medium text-gray-500">Name</p>
                        <p class="text-gray-900">{{ document.customer_name }}</p>
                    </div>
                    {% if document.customer_phone %}
                    <div>
                        <p class="text-sm font-medium text-gray-500">Telefon</p>
                        <p class="text-gray-900">{{ document.customer_phone }}</p>
                    </div>
                    {% endif %}
                    {% if document.customer_email %}
                    <div>
                        <p class="text-sm font-medium text-gray-500">E-Mail</p>
                        <p class="text-gray-900">{{ document.customer_email }}</p>
                    </div>
                    {% endif %}
                </div>
            </div>

            <!-- Geräteinformationen -->
            <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-6">
                <h3 class="text-lg font-medium text-gray-900 mb-4 flex items-center">
                    <svg class="w-5 h-5 text-emerald-600 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 18h.01M8 21h8a2 2 0 002-2V5a2 2 0 00-2-2H8a2 2 0 00-2 2v14a2 2 0 002 2z"/>
                    </svg>
                    Gerät
                </h3>
                <div class="bg-gray-50 rounded-lg p-4 space-y-3">
                    <div>
                        <p class="text-sm font-medium text-gray-500">Gerät</p>
                        <p class="text-gray-900 font-medium">{{ assessment.device_name }}</p>
                    </div>
                    <div>
                        <p class="text-sm font-medium text-gray-500">Seriennummer / IMEI</p>
                        <p class="text-gray-900 font-mono">{{ assessment.serial_number }}</p>
                    </div>
                </div>
            </div>

            <!-- Schadensbewertung -->
            <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-6">
                <h3 class="text-lg font-medium text-gray-900 mb-4 flex items-center">
                    <svg class="w-5 h-5 text-emerald-600 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/>
                    </svg>
                    Schadensbewertung
                </h3>
                {% if assessment.damage_description %}
                    <div class="prose prose-sm mb-4">{{ assessment.damage_description|raw }}</div>
                {% endif %}
            </div>

            <!-- Bewertungsergebnis -->
            {% if assessment.assessment_result == 'total_loss' %}
                <div class="bg-gradient-to-r from-red-500 to-red-600 rounded-lg shadow-sm p-6 text-white">
            {% elseif assessment.assessment_result == 'repair_recommended' %}
                <div class="bg-gradient-to-r from-emerald-500 to-emerald-600 rounded-lg shadow-sm p-6 text-white">
            {% else %}
                <div class="bg-gradient-to-r from-gray-500 to-gray-600 rounded-lg shadow-sm p-6 text-white">
            {% endif %}
                <div class="text-center mb-4">
                    <p class="text-sm font-medium opacity-80 mb-1">Bewertungsergebnis</p>
                    <p class="text-2xl font-bold">{{ assessment.assessment_result_label }}</p>
                </div>
                <div class="grid grid-cols-2 gap-4 pt-4 border-t border-white border-opacity-30">
                    <div class="text-center">
                        <p class="text-sm opacity-80 mb-1">Geschätzter Zeitwert</p>
                        <p class="text-xl font-bold">{{ assessment.formatted_device_value }}</p>
                    </div>
                    <div class="text-center">
                        <p class="text-sm opacity-80 mb-1">Reparaturkosten</p>
                        <p class="text-xl font-bold">{{ assessment.formatted_repair_cost }}</p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}
